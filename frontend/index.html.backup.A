async function loadSchedule(){
    await loadAllData();
    document.getElementById('scheduleView').innerHTML='<div class="empty">请选择老师查看课表</div>';
}

async function loadTeacherSchedule(){
    const teacherId=document.getElementById('teacherSelect').value;
    const weekFilter=document.getElementById('weekSelect').value;
    if(!teacherId){document.getElementById('scheduleView').innerHTML='<div class="empty">请选择老师查看课表</div>';return;}
    data.schedules=await fetch(API+'/schedules').then(r=>r.json());
    const teacher=data.teachers.find(t=>t.id===teacherId);
    let mySchedules=data.schedules.filter(s=>s.teacherId===teacherId);
    
    // 按周次筛选 - 修复：使用精确匹配而不是字符串包含，支持范围格式如 "1-16"
    if(weekFilter!=='all'){
        const targetWeek=parseInt(weekFilter);
        mySchedules=mySchedules.filter(s=>{
            const weekParts=s.weeks.split(',');
            for(const part of weekParts){
                if(part.includes('-')){
                    const[start,end]=part.split('-').map(Number);
                    if(targetWeek>=start&&targetWeek<=end)return true;
                }else if(parseInt(part)===targetWeek){
                    return true;
                }
            }
            return false;
        });
    }
    
    if(!mySchedules.length){document.getElementById('scheduleView').innerHTML='<div class="empty">该老师暂无排课</div>';return;}
    const days=['周一','周二','周三','周四','周五'];
    let html='<h3 style="margin-bottom:15px">'+teacher.name+' 老师课表';
    if(weekFilter!=='all')html+=' (第'+weekFilter+'周)';
    else html+=' (全部周次 - 单双周交替显示)';
    html+='</h3>';
    html+='<table class="schedule-table"><thead><tr><th>时间</th>';
    days.forEach(d=>html+='<th>'+d+'</th>');
    html+='</tr></thead><tbody>';
    for(let s=1;s<=8;s++){
        html+='<tr><td>第'+s+'节</td>';
        for(let d=1;d<=5;d++){
            const sc=mySchedules.filter(x=>x.dayOfWeek===d&&x.startSection<=s&&x.endSection>=s);
            if(sc.length){
                // 在"全部周"模式下，如果同一时间段有多门课（单双周交替），需要特殊显示
                if(weekFilter==='all' && sc.length>1){
                    html+='<td>'+sc.map(x=>{
                        const isSingle=x.weeks.includes('1')&&x.weeks.includes('3');
                        const weekBadge=isSingle?'<span style="background:#e3f2fd;color:#1976d2;padding:2px 6px;border-radius:4px;font-size:10px;margin-right:4px;">单</span>':'<span style="background:#f3e5f5;color:#7b1fa2;padding:2px 6px;border-radius:4px;font-size:10px;margin-right:4px;">双</span>';
                        return'<div class="schedule-cell" style="margin-bottom:4px;"><div class="course">'+weekBadge+x.courseName+'</div><div class="room">'+x.classroomName+'</div><div class="cls">'+x.className+'</div></div>';
                    }).join('')+'</td>';
                }else{
                    html+='<td>'+sc.map(x=>'<div class="schedule-cell"><div class="course">'+x.courseName+'</div><div class="room">'+x.classroomName+'</div><div class="cls">'+x.className+'</div></div>').join('')+'</td>';
                }
            }else html+='<td class="empty-cell"></td>';
        }
        html+='</tr>';
    }
    html+='</tbody></table>';
    document.getElementById('scheduleView').innerHTML=html;
}

async function loadClassSchedule(){
    const classId=document.getElementById('classSelect').value;
    const weekFilter=document.getElementById('classWeekSelect').value;
    if(!classId){document.getElementById('classScheduleView').innerHTML='';return;}
    data.schedules=await fetch(API+'/schedules').then(r=>r.json());
    const cls=data.classes.find(c=>c.id===classId);
    let mySchedules=data.schedules.filter(s=>s.classId===classId);
    
    // 按周次筛选 - 修复：使用精确匹配而不是字符串包含，支持范围格式如 "1-16"
    if(weekFilter!=='all'){
        const targetWeek=parseInt(weekFilter);
        mySchedules=mySchedules.filter(s=>{
            const weekParts=s.weeks.split(',');
            for(const part of weekParts){
                if(part.includes('-')){
                    const[start,end]=part.split('-').map(Number);
                    if(targetWeek>=start&&targetWeek<=end)return true;
                }else if(parseInt(part)===targetWeek){
                    return true;
                }
            }
            return false;
        });
    }
    
    if(!mySchedules.length){document.getElementById('classScheduleView').innerHTML='<div class="empty">该班级暂无排课</div>';return;}
    const days=['周一','周二','周三','周四','周五'];
    let html='<h3 style="margin-bottom:15px">'+cls.name+' 课表';
    if(weekFilter!=='all')html+=' (第'+weekFilter+'周)';
    else html+=' (全部周次 - 单双周交替显示)';
    html+='</h3>';
    html+='<table class="schedule-table"><thead><tr><th>时间</th>';
    days.forEach(d=>html+='<th>'+d+'</th>');
    html+='</tr></thead><tbody>';
    for(let s=1;s<=8;s++){
        html+='<tr><td>第'+s+'节</td>';
        for(let d=1;d<=5;d++){
            const sc=mySchedules.filter(x=>x.dayOfWeek===d&&x.startSection<=s&&x.endSection>=s);
            if(sc.length){
                // 在"全部周"模式下，如果同一时间段有多门课（单双周交替），需要特殊显示
                if(weekFilter==='all' && sc.length>1){
                    html+='<td>'+sc.map(x=>{
                        const isSingle=x.weeks.includes('1')&&x.weeks.includes('3');
                        const weekBadge=isSingle?'<span style="background:#e3f2fd;color:#1976d2;padding:2px 6px;border-radius:4px;font-size:10px;margin-right:4px;">单</span>':'<span style="background:#f3e5f5;color:#7b1fa2;padding:2px 6px;border-radius:4px;font-size:10px;margin-right:4px;">双</span>';
                        return'<div class="schedule-cell" style="margin-bottom:4px;"><div class="course">'+weekBadge+x.courseName+'</div><div class="room">'+x.classroomName+'</div><div class="cls">'+x.teacherName+'</div></div>';
                    }).join('')+'</td>';
                }else{
                    html+='<td>'+sc.map(x=>'<div class="schedule-cell"><div class="course">'+x.courseName+'</div><div class="room">'+x.classroomName+'</div><div class="cls">'+x.teacherName+'</div></div>').join('')+'</td>';
                }
            }else html+='<td class="empty-cell"></td>';
        }
        html+='</tr>';
    }
    html+='</tbody></table>';
    document.getElementById('classScheduleView').innerHTML=html;
}

async function autoSchedule(){
    await fetch(API+'/schedules/auto',{method:'POST'});
    alert('智能排课完成');
    // 刷新当前老师课表
    const selectedTeacher=document.getElementById('teacherSelect').value;
    if(selectedTeacher)loadTeacherSchedule();
    // 刷新当前班级课表
    const selectedClass=document.getElementById('classSelect').value;
    if(selectedClass)loadClassSchedule();
}

async function clearSchedule(){
    if(!confirm('确定清空所有排课?'))return;
    await fetch(API+'/schedules',{method:'DELETE'});
    // 刷新当前老师课表
    const selectedTeacher=document.getElementById('teacherSelect').value;
    if(selectedTeacher)loadTeacherSchedule();
    // 刷新当前班级课表
    const selectedClass=document.getElementById('classSelect').value;
    if(selectedClass)loadClassSchedule();
}

function goToSection(section,editId){
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.querySelector('[data-section="'+section+'"]').classList.add('active');
    document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
    document.getElementById(section).classList.add('active');
    const titles={dashboard:'仪表盘',courses:'课程管理',teachers:'教师管理',students:'学生管理',classrooms:'教室管理',schedule:'排课管理','my-schedule':'我的课表','ai-assistant':'AI 助手'};
    document.getElementById('pageTitle').textContent=titles[section];
    loadSection(section).then(()=>{
        if(editId){
            if(section==='courses')openCourseModal(editId);
            else if(section==='teachers')openTeacherModal(editId);
            else if(section==='students')openStudentModal(editId);
            else if(section==='classrooms')openClassroomModal(editId);
        }
    });
}

async function showDetail(type){
    const container=document.getElementById('dashboardDetail');
    let html='<div style="background:#fff;padding:20px;border-radius:10px;margin-top:20px;"><div class="detail-header"><h3>';
    let items=[];
    if(type==='courses'){
        items=await fetch(API+'/courses').then(r=>r.json());
        html+='课程列表 ('+items.length+'门)</h3><button class="btn btn-primary" onclick="goToSection(\'courses\')">进入管理</button></div><div class="detail-list">';
        items.forEach(c=>html+='<div class="detail-item"><div class="info"><div class="name">'+c.name+'</div><div class="desc">'+c.id+' | '+c.category+' | '+c.credits+'学分</div></div><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="goToSection(\'courses\',\''+c.id+'\')">编辑</button></div></div>');
    }else if(type==='teachers'){
        items=await fetch(API+'/teachers').then(r=>r.json());
        html+='教师列表 ('+items.length+'人)</h3><button class="btn btn-primary" onclick="goToSection(\'teachers\')">进入管理</button></div><div class="detail-list">';
        items.forEach(t=>html+='<div class="detail-item"><div class="info"><div class="name">'+t.name+'</div><div class="desc">'+t.id+' | '+t.subject+'</div></div><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="goToSection(\'teachers\',\''+t.id+'\')">编辑</button></div></div>');
    }else if(type==='students'){
        items=await fetch(API+'/students').then(r=>r.json());
        html+='学生列表 ('+items.length+'人)</h3><button class="btn btn-primary" onclick="goToSection(\'students\')">进入管理</button></div><div class="detail-list">';
        items.slice(0,20).forEach(s=>html+='<div class="detail-item"><div class="info"><div class="name">'+s.name+'</div><div class="desc">'+s.id+' | '+(s.class||'')+'</div></div><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="goToSection(\'students\',\''+s.id+'\')">编辑</button></div></div>');
    }else if(type==='classrooms'){
        items=await fetch(API+'/classrooms').then(r=>r.json());
        html+='教室列表 ('+items.length+'间)</h3><button class="btn btn-primary" onclick="goToSection(\'classrooms\')">进入管理</button></div><div class="detail-list">';
        items.forEach(r=>html+='<div class="detail-item"><div class="info"><div class="name">'+r.name+'</div><div class="desc">'+r.id+' | '+r.capacity+'人 | '+r.building+'</div></div><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="goToSection(\'classrooms\',\''+r.id+'\')">编辑</button></div></div>');
    }
    html+='</div></div>';
    container.innerHTML=html;
}

// ============ AI 聊天功能 ============
let chatHistory = [];
let currentAIModel = { provider: 'codingplan', model: 'qwen3-max-2026-01-23' };

// 初始化模型选择器
async function initModelSelector() {
    try {
        const response = await fetch(API + '/ai/model');
        const data = await response.json();
        currentAIModel = { provider: data.provider, model: data.model };
        
        const selector = document.getElementById('modelSelector');
        if (selector) {
            selector.value = data.provider + '|' + data.model;
        }
        
        console.log('当前 AI 模型:', currentAIModel);
    } catch (e) {
        console.error('加载模型配置失败:', e);
    }
}

// 切换 AI 模型
async function changeAIModel() {
    const selector = document.getElementById('modelSelector');
    const [provider, model] = selector.value.split('|');
    
    try {
        const response = await fetch(API + '/ai/model', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ provider, model })
        });
        
        const result = await response.json();
        if (result.success) {
            currentAIModel = { provider, model };
            addChatMessage('ai', `✅ 已切换到 ${getModelDisplayName(provider, model)}`);
            
            // 如果是 OpenClaw 模式，显示特殊提示
            if (provider === 'openclaw') {
                addChatMessage('ai', '💡 OpenClaw 模式已启用。请在当前 OpenClaw 会话中直接提问排课相关问题。');
            }
        } else {
            addChatMessage('ai', '❌ 切换模型失败: ' + result.error);
        }
    } catch (e) {
        addChatMessage('ai', '❌ 切换模型出错: ' + e.message);
    }
}

// 获取模型显示名称
function getModelDisplayName(provider, model) {
    const names = {
        'codingplan': 'CodingPlan',
        'ollama': '本地 Ollama',
        'openclaw': 'OpenClaw'
    };
    return names[provider] || provider;
}

function initChat() {
    const input = document.getElementById('chatInput');
    if (input) {
        input.focus();
    }
}

async function sendChatMessage() {
    const input = document.getElementById('chatInput');
    const sendBtn = document.getElementById('chatSendBtn');
    const message = input.value.trim();
    
    if (!message) return;
    
    // 添加用户消息
    addChatMessage('user', message);
    input.value = '';
    
    // 显示输入中状态
    showTypingIndicator();
    sendBtn.disabled = true;
    
    try {
        // 调用 AI 接口
        const response = await fetch(API + '/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message })
        });
        
        const result = await response.json();
        
        // 移除输入中状态
        removeTypingIndicator();
        
        // 处理 OpenClaw 模式
        if (result.openclawMode) {
            addChatMessage('ai', result.reply);
            sendBtn.disabled = false;
            return;
        }
        
        // 添加 AI 回复
        addChatMessage('ai', result.reply, result);
        
        // 自动排课直接执行，不需要确认
        if (result.intent === 'auto' && !result.needsConfirm) {
            // 延迟一下显示执行中状态
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execResponse = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'auto', params: result.params })
                    });
                    const execResult = await execResponse.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        addChatMessage('ai', '✅ ' + execResult.message + '\n\n📊 已生成 ' + (execResult.schedules?.length || 0) + ' 条排课记录');
                        await loadAllData();
                    } else {
                        addChatMessage('ai', '❌ 自动排课失败：' + execResult.error);
                    }
                } catch (e) {
                    removeTypingIndicator();
                    addChatMessage('ai', '❌ 执行出错：' + e.message);
                }
            }, 500);
        }
        
        // replace 指令直接执行
        if (result.intent === 'replace') {
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execResponse = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'replace', params: result.params })
                    });
                    const execResult = await execResponse.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        addChatMessage('ai', '✅ ' + execResult.message);
                        // 完全重新加载所有数据
                        await loadAllData();
                        // 强制刷新课表数据
                        data.schedules = await fetch(API+'/schedules').then(r=>r.json());
                        data.teachers = await fetch(API+'/teachers').then(r=>r.json());
                        data.courses = await fetch(API+'/courses').then(r=>r.json());
                        data.classes = await fetch(API+'/classes').then(r=>r.json());
                        // 刷新当前课表视图
                        const selectedTeacher = document.getElementById('teacherSelect')?.value;
                        const selectedClass = document.getElementById('classSelect')?.value;
                        if (selectedTeacher) {
                            await loadTeacherSchedule();
                            addChatMessage('ai', '📋 教师课表已更新，请查看"排课管理"页面');
                        }
                        if (selectedClass) {
                            await loadClassSchedule();
                            addChatMessage('ai', '📋 班级课表已更新，请查看"我的课表"页面');
                        }
                        // 如果没有选中任何视图，提示用户手动刷新
                        if (!selectedTeacher && !selectedClass) {
                            addChatMessage('ai', '💡 课程已更换，请切换到"排课管理"或"我的课表"查看最新课表');
                        }
                    } else {
                        const errorMsg = execResult.message || execResult.error || '操作失败';
                        addChatMessage('ai', '❌ 更换课程失败：' + errorMsg);
                    }
                } catch (e) {
                    removeTypingIndicator();
                    addChatMessage('ai', '❌ 执行出错：' + e.message);
                }
            }, 500);
        }
        
        // delete 指令直接执行
        if (result.intent === 'delete') {
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execResponse = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'delete', params: result.params })
                    });
                    const execResult = await execResponse.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        addChatMessage('ai', '✅ ' + execResult.message);
                        // 完全重新加载所有数据
                        await loadAllData();
                        // 强制刷新课表数据
                        data.schedules = await fetch(API+'/schedules').then(r=>r.json());
                        // 刷新当前课表视图
                        const selectedTeacher = document.getElementById('teacherSelect')?.value;
                        const selectedClass = document.getElementById('classSelect')?.value;
                        if (selectedTeacher) {
                            await loadTeacherSchedule();
                            addChatMessage('ai', '📋 教师课表已更新，请查看"排课管理"页面');
                        }
                        if (selectedClass) {
                            await loadClassSchedule();
                            addChatMessage('ai', '📋 班级课表已更新，请查看"我的课表"页面');
                        }
                        // 如果没有选中任何视图，提示用户手动刷新
                        if (!selectedTeacher && !selectedClass) {
                            addChatMessage('ai', '💡 课程已删除，请切换到"排课管理"或"我的课表"查看最新课表');
                        }
                    } else {
                        const errorMsg = execResult.message || execResult.error || '操作失败';
                        addChatMessage('ai', '❌ 删除课程失败：' + errorMsg);
                    }
                } catch (e) {
                    removeTypingIndicator();
                    addChatMessage('ai', '❌ 执行出错：' + e.message);
                }
            }, 500);
        }
        
        // move 指令直接执行
        if (result.intent === 'move') {
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execResponse = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'move', params: result.params })
                    });
                    const execResult = await execResponse.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        addChatMessage('ai', '✅ ' + execResult.message);
                        await loadAllData();
                        data.schedules = await fetch(API+'/schedules').then(r=>r.json());
                        const selectedTeacher = document.getElementById('teacherSelect')?.value;
                        const selectedClass = document.getElementById('classSelect')?.value;
                        if (selectedTeacher) await loadTeacherSchedule();
                        if (selectedClass) await loadClassSchedule();
                        if (!selectedTeacher && !selectedClass) {
                            addChatMessage('ai', '💡 课程已移动，请切换到"排课管理"或"我的课表"查看最新课表');
                        }
                    } else {
                        const errorMsg = execResult.message || execResult.error || '操作失败';
                        addChatMessage('ai', '❌ 移动课程失败：' + errorMsg);
                    }
                } catch (e) {
                    removeTypingIndicator();
                    addChatMessage('ai', '❌ 执行出错：' + e.message);
                }
            }, 500);
        }
        
        // check 指令直接执行
        if (result.intent === 'check') {
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execResponse = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'check', params: result.params })
                    });
                    const execResult = await execResponse.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        let message = '✅ ' + execResult.message;
                        if (execResult.conflicts && execResult.conflicts.length > 0) {
                            message += '\n\n发现以下冲突：\n' + execResult.conflicts.map(c => 
                                `• ${c.type}: ${c.description}`
                            ).join('\n');
                        }
                        addChatMessage('ai', message);
                    } else {
                        const errorMsg = execResult.message || execResult.error || '操作失败';
                        addChatMessage('ai', '❌ 检查冲突失败：' + errorMsg);
                    }
                } catch (e) {
                    removeTypingIndicator();
                    addChatMessage('ai', '❌ 执行出错：' + e.message);
                }
            }, 500);
        }
        
        // 如果需要确认（非自动排课/replace/delete/move/check），显示确认按钮
        if (result.needsConfirm && result.intent !== 'unknown' && result.intent !== 'auto' && result.intent !== 'replace' && result.intent !== 'delete' && result.intent !== 'move' && result.intent !== 'check') {
            showConfirmButtons(result);
        }
        
        // 显示快速操作按钮
        if (!document.querySelector('.chat-action-btns')) {
            showQuickActionButtons();
        }
        
    } catch (error) {
        removeTypingIndicator();
        addChatMessage('ai', '抱歉，服务暂时不可用，请稍后再试。');
    }
    
    sendBtn.disabled = false;
}

function addChatMessage(sender, text, data) {
    const container = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'chat-message ' + sender;
    
    let html = '<div class="chat-avatar">';
    html += sender === 'ai' ? '<i class="fas fa-robot"></i>' : '<i class="fas fa-user"></i>';
    html += '</div><div class="chat-bubble">' + escapeHtml(text) + '</div>';
    
    div.innerHTML = html;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    
    // 保存到历史
    chatHistory.push({ sender, text, data, time: new Date() });
}

function showTypingIndicator() {
    const container = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'chat-message ai typing';
    div.id = 'typingIndicator';
    div.innerHTML = '<div class="chat-avatar"><i class="fas fa-robot"></i></div>' +
        '<div class="chat-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
}

function removeTypingIndicator() {
    const indicator = document.getElementById('typingIndicator');
    if (indicator) {
        indicator.remove();
    }
}

function showConfirmButtons(result) {
    const container = document.getElementById('chatMessages');
    const lastMessage = container.lastElementChild;
    
    const confirmDiv = document.createElement('div');
    confirmDiv.className = 'chat-confirm-box';
    confirmDiv.innerHTML = '<div>确认执行此操作吗？</div>' +
        '<div class="chat-confirm-btns">' +
        '<button class="btn btn-success" onclick="executeAIAction(' + JSON.stringify(result).replace(/"/g, '&quot;') + ')">确认执行</button>' +
        '<button class="btn btn-danger" onclick="this.parentElement.parentElement.remove()">取消</button>' +
        '</div>';
    
    lastMessage.querySelector('.chat-bubble').appendChild(confirmDiv);
}

// 显示快速操作按钮（OpenClaw 模式）
function showQuickActionButtons() {
    const container = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'chat-message ai';
    div.innerHTML = '<div class="chat-avatar"><i class="fas fa-robot"></i></div>' +
        '<div class="chat-bubble">' +
        '<div style="margin-bottom:10px;">您可以直接问我：</div>' +
        '<div class="chat-action-btns">' +
        '<button class="chat-action-btn" onclick="sendQuickMessage(\'查询所有课程\')">📚 查询课程</button>' +
        '<button class="chat-action-btn" onclick="sendQuickMessage(\'查询教师列表\')">👨‍🏫 查询教师</button>' +
        '<button class="chat-action-btn" onclick="sendQuickMessage(\'检查课程冲突\')">⚠️ 检查冲突</button>' +
        '<button class="chat-action-btn" onclick="sendQuickMessage(\'自动排课\')">🤖 自动排课</button>' +
        '</div></div>';
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
}

// 快速发送消息
function sendQuickMessage(text) {
    const input = document.getElementById('chatInput');
    input.value = text;
    sendChatMessage();
}

async function executeAIAction(result) {
    try {
        const response = await fetch(API + '/ai/execute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ intent: result.intent, params: result.params })
        });
        
        const execResult = await response.json();
        
        if (execResult.success) {
            addChatMessage('ai', '✅ ' + execResult.message);
            // 刷新相关数据
            await loadAllData();
            if (document.getElementById('schedule').classList.contains('active')) {
                loadSchedule();
            }
        } else {
            addChatMessage('ai', '❌ 执行失败：' + execResult.error);
        }
    } catch (error) {
        addChatMessage('ai', '❌ 执行出错：' + error.message);
    }
    
    // 移除确认按钮
    document.querySelectorAll('.chat-confirm-box').forEach(el => el.remove());
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

init();
    </script>
</body>
</html>