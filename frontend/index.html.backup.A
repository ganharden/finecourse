function openScheduleModal(){
    const courseOpts=data.courses.map(c=>'<option value="'+c.id+'">'+c.name+'</option>').join('');
    const teacherOpts=data.teachers.map(t=>'<option value="'+t.id+'">'+t.name+' - '+t.subject+'</option>').join('');
    const classroomOpts=data.classrooms.map(r=>'<option value="'+r.id+'">'+r.name+' ('+r.building+', '+r.capacity+'人)</option>').join('');
    const classOpts=data.classes.map(c=>'<option value="'+c.id+'">'+c.name+'</option>').join('');
    const html='<h2>手动排课<button onclick="closeModal()">×</button></h2>'+
        '<form onsubmit="saveSchedule(event)">'+
        '<div class="form-group"><label>课程 *</label><select name="courseId" required><option value="">请选择课程</option>'+courseOpts+'</select></div>'+
        '<div class="form-group"><label>教师 *</label><select name="teacherId" required><option value="">请选择教师</option>'+teacherOpts+'</select></div>'+
        '<div class="form-group"><label>班级 *</label><select name="classId" required><option value="">请选择班级</option>'+classOpts+'</select></div>'+
        '<div class="form-group"><label>教室 *</label><select name="classroomId" required><option value="">请选择教室</option>'+classroomOpts+'</select></div>'+
        '<div class="form-row"><div class="form-group"><label>星期</label><select name="dayOfWeek" required><option value="1">周一</option><option value="2">周二</option><option value="3">周三</option><option value="4">周四</option><option value="5">周五</option></select></div><div class="form-group"><label>周次</label><input name="weeks" value="1-16" placeholder="如: 1-16"></div></div>'+
        '<div class="form-row"><div class="form-group"><label>开始节次 (1-8)</label><input name="startSection" type="number" min="1" max="8" value="1" required></div><div class="form-group"><label>结束节次 (1-8)</label><input name="endSection" type="number" min="1" max="8" value="2" required></div></div>'+
        '<div class="modal-actions"><button type="button" class="btn btn-danger" onclick="closeModal()">取消</button><button type="submit" class="btn btn-success">保存</button></div></form>';
    document.getElementById('modalContent').innerHTML=html;
    document.getElementById('modal').classList.add('active');
}

function openAutoScheduleModal(){
    // 多选老师
    const teacherCheckboxes=data.teachers.map(t=>'<label style="display:inline-block;margin:5px;padding:8px;background:#f0f0f0;border-radius:5px;cursor:pointer"><input type="checkbox" name="teacher" value="'+t.id+'" style="margin-right:5px">'+t.name+' ('+t.subject+')</label>').join('');
    // 周次选择
    const weekOptions=[];
    for(let i=1;i<=16;i++)weekOptions.push('<option value="'+i+'">第'+i+'周</option>');
    const html='<h2>智能排课<button onclick="closeModal()">×</button></h2>'+
        '<div class="form-group" style="margin-bottom:15px"><label>选择周次</label><select id="autoScheduleWeek" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px"><option value="all">全周(1-16周)</option>'+weekOptions.join('')+'</select></div>'+
        '<p style="margin-bottom:15px;color:#666">选择需要排课的老师（不选则所有老师都参与排课）：</p>'+
        '<div style="max-height:200px;overflow-y:auto;margin-bottom:15px;">'+teacherCheckboxes+'</div>'+
        '<p style="font-size:12px;color:#999">为选中的周次排课，每周独立不冲突</p>'+
        '<div class="modal-actions"><button type="button" class="btn btn-danger" onclick="closeModal()">取消</button><button type="button" class="btn btn-success" onclick="doAutoSchedule()">开始排课</button></div>';
    document.getElementById('modalContent').innerHTML=html;
    document.getElementById('modal').classList.add('active');
}

async function doAutoSchedule(){
    const checkboxes=document.querySelectorAll('input[name="teacher"]:checked');
    const teacherIds=Array.from(checkboxes).map(c=>c.value);
    const weekSelect=document.getElementById('autoScheduleWeek');
    const selectedWeek=weekSelect?weekSelect.value:'all';
    closeModal();
    
    // 构建请求参数
    const requestBody={teacherIds:teacherIds.length>0?teacherIds:null};
    if(selectedWeek!=='all'){
        // 指定具体周次，只排那一周
        requestBody.specificWeeks=selectedWeek;
    }else{
        // 全周模式
        requestBody.weekType='all';
    }
    
    const res=await fetch(API+'/schedules/auto',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify(requestBody)
    });
    const d=await res.json();
    alert('智能排课完成！添加了 '+d.added+' 条课表');
    // 刷新当前老师课表
    const selectedTeacher=document.getElementById('teacherSelect').value;
    if(selectedTeacher)loadTeacherSchedule();
    // 刷新当前班级课表
    const selectedClass=document.getElementById('classSelect').value;
    if(selectedClass)loadClassSchedule();
}

async function saveSchedule(e){
    e.preventDefault();
    const f=e.target;
    if(parseInt(f.startSection.value)>parseInt(f.endSection.value)){
        alert('开始节次不能大于结束节次');
        return;
    }
    const d={
        courseId:f.courseId.value,
        teacherId:f.teacherId.value,
        classId:f.classId.value,
        classroomId:f.classroomId.value,
        dayOfWeek:parseInt(f.dayOfWeek.value),
        startSection:parseInt(f.startSection.value),
        endSection:parseInt(f.endSection.value),
        weeks:f.weeks.value||'1-16'
    };
    await fetch(API+'/schedules',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});
    closeModal();
    // 刷新当前老师课表
    const selectedTeacher=document.getElementById('teacherSelect').value;
    if(selectedTeacher)loadTeacherSchedule();
    // 刷新当前班级课表
    const selectedClass=document.getElementById('classSelect').value;
    if(selectedClass)loadClassSchedule();
    alert('排课成功');
}

function closeModal(){
    document.getElementById('modal').classList.remove('active');
}

async function saveCourse(e,id){
    e.preventDefault();
    const f=e.target;
    const d={id:f.id.value,name:f.name.value,category:f.category.value,credits:parseInt(f.credits.value),maxStudents:parseInt(f.maxStudents.value)};
    await fetch(API+'/courses'+(id?'/'+id:''),{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});
    closeModal();
    loadCourses();
    loadStats();
}

async function saveTeacher(e,id){
    e.preventDefault();
    const f=e.target;
    const d={id:f.id.value,name:f.name.value,gender:f.gender.value,subject:f.subject.value,phone:f.phone.value,maxHours:parseInt(f.maxHours.value),office:f.office.value};
    await fetch(API+'/teachers'+(id?'/'+id:''),{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});
    closeModal();
    loadTeachers();
    loadStats();
}

async function saveStudent(e,id){
    e.preventDefault();
    const f=e.target;
    const d={id:f.id.value,name:f.name.value,gender:f.gender.value,class:f.class.value,major:f.major.value,grade:f.grade.value};
    await fetch(API+'/students'+(id?'/'+id:''),{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});
    closeModal();
    loadStudents();
    loadStats();
}

async function saveClassroom(e,id){
    e.preventDefault();
    const f=e.target;
    const d={id:f.id.value,name:f.name.value,capacity:parseInt(f.capacity.value),building:f.building.value,type:f.type.value,equipment:['投影仪','电脑','音响']};
    await fetch(API+'/classrooms'+(id?'/'+id:''),{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});
    closeModal();
    loadClassrooms();
    loadStats();
}

async function deleteCourse(id){
    if(!confirm('确定删除?'))return;
    await fetch(API+'/courses/'+id,{method:'DELETE'});
    loadCourses();
    loadStats();
}

async function deleteTeacher(id){
    if(!confirm('确定删除?'))return;
    await fetch(API+'/teachers/'+id,{method:'DELETE'});
    loadTeachers();
    loadStats();
}

async function deleteStudent(id){
    if(!confirm('确定删除?'))return;
    await fetch(API+'/students/'+id,{method:'DELETE'});
    loadStudents();
    loadStats();
}

async function deleteClassroom(id){
    if(!confirm('确定删除?'))return;
