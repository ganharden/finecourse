// 数据存储
let data = {courses:[], teachers:[], students:[], classrooms:[], classes:[], schedules:[]};
let isOnline = true;

// ========== 初始化 ==========
async function init(){
    updateTime();
    setInterval(updateTime, 1000);
    
    // 检测网络状态
    window.addEventListener('online', checkNetwork);
    window.addEventListener('offline', checkNetwork);
    await checkNetwork();
    
    // 加载数据
    await loadAllData();
    
    // 导航事件
    document.querySelectorAll('.nav-item').forEach(item=>{
        item.onclick=()=>{
            document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
            item.classList.add('active');
            document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
            const section = item.dataset.section;
            document.getElementById(section).classList.add('active');
            
            const titles={dashboard:'仪表盘',courses:'课程管理',teachers:'教师管理',students:'学生管理',classrooms:'教室管理',schedule:'排课管理','my-schedule':'我的课表','ai-assistant':'AI 助手'};
            document.getElementById('pageTitle').textContent=titles[section];
            
            // 关闭移动端菜单
            document.getElementById('sidebar').classList.remove('open');
            document.querySelector('.menu-overlay').classList.remove('active');
            
            loadSection(section);
        };
    });
}

function updateTime(){
    document.getElementById('currentTime').textContent = new Date().toLocaleString('zh-CN');
}

// ========== 网络检测 ==========
async function checkNetwork(){
    const statusEl = document.getElementById('networkStatus');
    const aiStatus = document.getElementById('aiStatus');
    
    try {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 3000);
        
        await fetch(API + '/stats', { signal: controller.signal });
        clearTimeout(timeout);
        
        isOnline = true;
        statusEl.style.display = 'none';
        aiStatus.textContent = '在线 - 智能管理你的课表';
        aiStatus.style.color = '';
    } catch (e) {
        isOnline = false;
        statusEl.style.display = 'flex';
        statusEl.className = 'network-status offline';
        aiStatus.textContent = '离线模式 - AI功能不可用';
        aiStatus.style.color = '#e65100';
    }
}

// ========== 数据加载 ==========
async function loadAllData(){
    if (isOnline) {
        try {
            data.courses = await fetch(API+'/courses').then(r=>r.json()).catch(()=>offlineData.courses);
            data.teachers = await fetch(API+'/teachers').then(r=>r.json()).catch(()=>offlineData.teachers);
            data.students = await fetch(API+'/students').then(r=>r.json()).catch(()=>offlineData.students);
            data.classrooms = await fetch(API+'/classrooms').then(r=>r.json()).catch(()=>offlineData.classrooms);
            data.classes = await fetch(API+'/classes').then(r=>r.json()).catch(()=>offlineData.classes);
            data.schedules = await fetch(API+'/schedules').then(r=>r.json()).catch(()=>offlineData.schedules);
        } catch (e) {
            console.log('使用离线数据');
            data = {...offlineData};
        }
    } else {
        data = {...offlineData};
    }
    
    // 缓存到 localStorage
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    
    updateSelects();
    loadStats();
}

function updateSelects(){
    document.getElementById('teacherSelect').innerHTML = '<option value="">-- 请选择老师 --</option>' + 
        data.teachers.map(t=>`<option value="${t.id}">${t.name} - ${t.subject}</option>`).join('');
    document.getElementById('classSelect').innerHTML = '<option value="">-- 请选择班级 --</option>' + 
        data.classes.map(c=>`<option value="${c.id}">${c.name}</option>`).join('');
}

async function loadSection(section){
    switch(section){
        case 'dashboard': loadStats(); break;
        case 'courses': renderCourses(); break;
        case 'teachers': renderTeachers(); break;
        case 'students': renderStudents(); break;
        case 'classrooms': renderClassrooms(); break;
        case 'schedule': loadSchedule(); break;
        case 'my-schedule': loadClassSchedule(); break;
    }
}

// ========== 统计 ==========
function loadStats(){
    document.getElementById('statCourses').textContent = data.courses.length;
    document.getElementById('statTeachers').textContent = data.teachers.length;
    document.getElementById('statStudents').textContent = data.students.length;
    document.getElementById('statClassrooms').textContent = data.classrooms.length;
}

// ========== 列表渲染 ==========
function renderCourses(){
    const search = document.getElementById('courseSearch').value.toLowerCase();
    const list = data.courses.filter(c => c.name.toLowerCase().includes(search) || c.id.toLowerCase().includes(search));
    
    document.getElementById('coursesList').innerHTML = list.length ? 
        `<table><thead><tr><th>ID</th><th>名称</th><th>类别</th><th>学分</th><th>人数</th><th>操作</th></tr></thead>
        <tbody>${list.map(c=>`<tr><td>${c.id}</td><td>${c.name}</td><td>${c.category}</td><td>${c.credits}</td><td>${c.maxStudents}</td>
        <td><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="openCourseModal('${c.id}')">编辑</button>
        <button class="btn btn-sm btn-danger" onclick="deleteCourse('${c.id}')">删除</button></div></td></tr>`).join('')}</tbody></table>` :
        '<div class="empty"><i class="fas fa-book"></i><p>暂无课程数据</p></div>';
}

function renderTeachers(){
    const search = document.getElementById('teacherSearch').value.toLowerCase();
    const list = data.teachers.filter(t => t.name.toLowerCase().includes(search));
    
    document.getElementById('teachersList').innerHTML = list.length ?
        `<table><thead><tr><th>ID</th><th>姓名</th><th>科目</th><th>电话</th><th>办公室</th><th>操作</th></tr></thead>
        <tbody>${list.map(t=>`<tr><td>${t.id}</td><td>${t.name}</td><td>${t.subject}</td><td>${t.phone}</td><td>${t.office||''}</td>
        <td><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="openTeacherModal('${t.id}')">编辑</button>
        <button class="btn btn-sm btn-danger" onclick="deleteTeacher('${t.id}')">删除</button></div></td></tr>`).join('')}</tbody></table>` :
        '<div class="empty"><i class="fas fa-chalkboard-teacher"></i><p>暂无教师数据</p></div>';
}

function renderStudents(){
    const search = document.getElementById('studentSearch').value.toLowerCase();
    const list = data.students.filter(s => s.name.toLowerCase().includes(search) || (s.class && s.class.toLowerCase().includes(search)));
    
    document.getElementById('studentsList').innerHTML = list.length ?
        `<table><thead><tr><th>ID</th><th>姓名</th><th>班级</th><th>专业</th><th>操作</th></tr></thead>
        <tbody>${list.slice(0,50).map(s=>`<tr><td>${s.id}</td><td>${s.name}</td><td>${s.class||''}</td><td>${s.major||''}</td>
        <td><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="openStudentModal('${s.id}')">编辑</button>
        <button class="btn btn-sm btn-danger" onclick="deleteStudent('${s.id}')">删除</button></div></td></tr>`).join('')}</tbody></table>` :
        '<div class="empty"><i class="fas fa-user-graduate"></i><p>暂无学生数据</p></div>';
}

function renderClassrooms(){
    const search = document.getElementById('classroomSearch').value.toLowerCase();
    const list = data.classrooms.filter(r => r.name.toLowerCase().includes(search));
    
    document.getElementById('classroomsList').innerHTML = list.length ?
        `<table><thead><tr><th>ID</th><th>名称</th><th>容量</th><th>楼栋</th><th>类型</th><th>操作</th></tr></thead>
        <tbody>${list.map(r=>`<tr><td>${r.id}</td><td>${r.name}</td><td>${r.capacity}</td><td>${r.building}</td><td>${r.type||'普通教室'}</td>
        <td><div class="action-btns"><button class="btn btn-sm btn-warning" onclick="openClassroomModal('${r.id}')">编辑</button>
        <button class="btn btn-sm btn-danger" onclick="deleteClassroom('${r.id}')">删除</button></div></td></tr>`).join('')}</tbody></table>` :
        '<div class="empty"><i class="fas fa-door-open"></i><p>暂无教室数据</p></div>';
}

// ========== 课表 ==========
function loadSchedule(){
    document.getElementById('scheduleView').innerHTML = '<div class="empty"><i class="fas fa-calendar-alt"></i><p>请选择老师查看课表</p></div>';
}

function loadTeacherSchedule(){
    const teacherId = document.getElementById('teacherSelect').value;
    const weekFilter = document.getElementById('weekSelect').value;
    
    if(!teacherId){
        document.getElementById('scheduleView').innerHTML = '<div class="empty"><i class="fas fa-calendar-alt"></i><p>请选择老师查看课表</p></div>';
        return;
    }
    
    const teacher = data.teachers.find(t => t.id === teacherId);
    let mySchedules = data.schedules.filter(s => s.teacherId === teacherId);
    
    if(weekFilter !== 'all'){
        const targetWeek = parseInt(weekFilter);
        mySchedules = mySchedules.filter(s => {
            const weeks = parseWeeks(s.weeks);
            return weeks.includes(targetWeek);
        });
    }
    
    if(!mySchedules.length){
        document.getElementById('scheduleView').innerHTML = '<div class="empty"><i class="fas fa-calendar"></i><p>该老师暂无排课</p></div>';
        return;
    }
    
    const days = ['周一','周二','周三','周四','周五'];
    let html = `<h3 style="margin-bottom:16px;color:#1e3a5f">${teacher.name} 老师课表${weekFilter!=='all' ? ' (第'+weekFilter+'周)' : ''}</h3>`;
    html += '<div class="schedule-table"><table><thead><tr><th>时间</th>';
    days.forEach(d => html += `<th>${d}</th>`);
    html += '</tr></thead><tbody>';
    
    for(let s=1; s<=8; s++){
        html += `<tr><td style="background:#f8f9fa;font-weight:600">第${s}节</td>`;
        for(let d=1; d<=5; d++){
            const sc = mySchedules.filter(x => x.dayOfWeek === d && x.startSection <= s && x.endSection >= s);
            html += sc.length ? 
                `<td>${sc.map(x => `<div class="schedule-cell"><div class="course">${x.courseName||x.courseId}</div><div class="room">${x.classroomName||''}</div><div class="cls">${x.className||''}</div></div>`).join('')}</td>` :
                '<td class="empty-cell"></td>';
        }
        html += '</tr>';
    }
    html += '</tbody></table></div>';
    document.getElementById('scheduleView').innerHTML = html;
}

function loadClassSchedule(){
    const classId = document.getElementById('classSelect').value;
    const weekFilter = document.getElementById('classWeekSelect').value;
    
    if(!classId){
        document.getElementById('classScheduleView').innerHTML = '';
        return;
    }
    
    const cls = data.classes.find(c => c.id === classId);
    let mySchedules = data.schedules.filter(s => s.classId === classId);
    
    if(weekFilter !== 'all'){
        const targetWeek = parseInt(weekFilter);
        mySchedules = mySchedules.filter(s => {
            const weeks = parseWeeks(s.weeks);
            return weeks.includes(targetWeek);
        });
    }
    
    if(!mySchedules.length){
        document.getElementById('classScheduleView').innerHTML = '<div class="empty"><i class="fas fa-calendar"></i><p>该班级暂无排课</p></div>';
        return;
    }
    
    const days = ['周一','周二','周三','周四','周五'];
    let html = `<h3 style="margin-bottom:16px;color:#1e3a5f">${cls.name} 课表${weekFilter!=='all' ? ' (第'+weekFilter+'周)' : ''}</h3>`;
    html += '<div class="schedule-table"><table><thead><tr><th>时间</th>';
    days.forEach(d => html += `<th>${d}</th>`);
    html += '</tr></thead><tbody>';
    
    for(let s=1; s<=8; s++){
        html += `<tr><td style="background:#f8f9fa;font-weight:600">第${s}节</td>`;
        for(let d=1; d<=5; d++){
            const sc = mySchedules.filter(x => x.dayOfWeek === d && x.startSection <= s && x.endSection >= s);
            html += sc.length ? 
                `<td>${sc.map(x => `<div class="schedule-cell"><div class="course">${x.courseName||x.courseId}</div><div class="room">${x.classroomName||''}</div><div class="cls">${x.teacherName||''}</div></div>`).join('')}</td>` :
                '<td class="empty-cell"></td>';
        }
        html += '</tr>';
    }
    html += '</tbody></table></div>';
    document.getElementById('classScheduleView').innerHTML = html;
}

function parseWeeks(weeksStr){
    if(!weeksStr) return [];
    const weeks = [];
    weeksStr.split(',').forEach(p => {
        if(p.includes('-')){
            const [start, end] = p.split('-').map(Number);
            for(let i=start; i<=end; i++) weeks.push(i);
        } else {
            weeks.push(Number(p));
        }
    });
    return weeks;
}

