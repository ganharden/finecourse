// ========== 详情 ==========
async function showDetail(type){
    const container = document.getElementById('dashboardDetail');
    let items = [];
    let title = '';
    
    switch(type){
        case 'courses': items = data.courses; title = '课程'; break;
        case 'teachers': items = data.teachers; title = '教师'; break;
        case 'students': items = data.students.slice(0, 30); title = '学生'; break;
        case 'classrooms': items = data.classrooms; title = '教室'; break;
    }
    
    container.innerHTML = `<div style="background:#fff;padding:24px;border-radius:16px;margin-top:24px;box-shadow:0 2px 12px rgba(0,0,0,0.08)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
            <h3 style="color:#1e3a5f;font-size:18px">${title}列表 (${items.length})</h3>
            <button class="btn btn-primary" onclick="goToSection('${type}')">进入管理</button>
        </div>
        <div class="detail-list">${items.map(item => `
            <div class="detail-item">
                <div class="info"><div class="name">${item.name}</div>
                <div class="desc">${item.id} | ${item.category || item.subject || item.class || item.building || ''}</div></div>
            </div>
        `).join('')}</div>
    </div>`;
}

function goToSection(section){
    document.querySelector(`[data-section="${section}"]`).click();
}

// ========== AI 聊天 ==========
let chatHistory = [];

async function sendChatMessage() {
    const input = document.getElementById('chatInput');
    const sendBtn = document.getElementById('chatSendBtn');
    const message = input.value.trim();
    
    if (!message) return;
    
    addChatMessage('user', message);
    input.value = '';
    
    if (!isOnline) {
        addChatMessage('ai', '⚠️ 当前处于离线模式，AI 助手不可用。\n\n请确保手机和电脑在同一 WiFi 网络，或访问在线版本。');
        return;
    }
    
    showTypingIndicator();
    sendBtn.disabled = true;
    
    try {
        const response = await fetch(API + '/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message })
        });
        
        const result = await response.json();
        removeTypingIndicator();
        
        addChatMessage('ai', result.reply || '处理完成');
        
        // 执行操作
        if (result.intent === 'auto') {
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execRes = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'auto', params: result.params })
                    });
                    const execResult = await execRes.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        addChatMessage('ai', `✅ ${execResult.message}`);
                        await loadAllData();
                    } else {
                        addChatMessage('ai', `❌ ${execResult.error}`);
                    }
                } catch (e) {
                    removeTypingIndicator();
                    addChatMessage('ai', '❌ 执行出错: ' + e.message);
                }
            }, 500);
        }
        
        if (result.intent === 'query') {
            setTimeout(async () => {
                showTypingIndicator();
                try {
                    const execRes = await fetch(API + '/ai/execute', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ intent: 'query', params: result.params })
                    });
                    const execResult = await execRes.json();
                    removeTypingIndicator();
                    if (execResult.success) {
                        addChatMessage('ai', execResult.message);
                    }
                } catch (e) {
                    removeTypingIndicator();
                }
            }, 500);
        }
        
    } catch (error) {
        removeTypingIndicator();
        addChatMessage('ai', '抱歉，服务暂时不可用。请检查网络连接。');
    }
    
    sendBtn.disabled = false;
}

function addChatMessage(sender, text) {
    const container = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'chat-message ' + sender;
    div.innerHTML = `<div class="chat-avatar"><i class="fas fa-${sender === 'ai' ? 'robot' : 'user'}"></i></div>
        <div class="chat-bubble">${text.replace(/\n/g, '<br>')}</div>`;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
}

function showTypingIndicator() {
    const container = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'chat-message ai typing';
    div.id = 'typingIndicator';
    div.innerHTML = '<div class="chat-avatar"><i class="fas fa-robot"></i></div>' +
        '<div class="chat-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
}

function removeTypingIndicator() {
    const indicator = document.getElementById('typingIndicator');
    if (indicator) indicator.remove();
}

// ========== 启动 ==========
init();
    </script>
    
    <!-- PWA Service Worker -->
    <script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js').catch(e => console.log('SW注册失败:', e));
        });
    }
    </script>
</body>
</html>