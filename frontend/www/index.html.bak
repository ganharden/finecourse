    if(!confirm('确定删除?')) return;
    if(isOnline) await fetch(API+'/teachers/'+id, {method: 'DELETE'});
    data.teachers = data.teachers.filter(t => t.id !== id);
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    renderTeachers();
    loadStats();
    updateSelects();
}

