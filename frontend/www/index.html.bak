// ========== 数据保存 ==========
async function saveCourse(e, id){
    e.preventDefault();
    const f = e.target;
    const item = {id: f.id.value, name: f.name.value, category: f.category.value, credits: parseInt(f.credits.value), maxStudents: parseInt(f.maxStudents.value)};
    
    if(isOnline){
        await fetch(API+'/courses'+(id?'/'+id:''), {method: id?'PUT':'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(item)});
    }
    
    if(id){
        const idx = data.courses.findIndex(c => c.id === id);
        if(idx >= 0) data.courses[idx] = item;
    } else {
        data.courses.push(item);
    }
    
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    closeModal();
    renderCourses();
    loadStats();
}

async function saveTeacher(e, id){
    e.preventDefault();
    const f = e.target;
    const item = {id: f.id.value, name: f.name.value, subject: f.subject.value, phone: f.phone.value, office: f.office.value, maxHours: 16};
    
    if(isOnline){
        await fetch(API+'/teachers'+(id?'/'+id:''), {method: id?'PUT':'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(item)});
    }
    
    if(id){
        const idx = data.teachers.findIndex(t => t.id === id);
        if(idx >= 0) data.teachers[idx] = item;
    } else {
        data.teachers.push(item);
    }
    
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    closeModal();
    renderTeachers();
    loadStats();
    updateSelects();
}

