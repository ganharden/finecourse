async function saveSchedule(e){
    e.preventDefault();
    const f = e.target;
    const item = {
        id: 'SCH' + Date.now(),
        courseId: f.courseId.value,
        teacherId: f.teacherId.value,
        classId: f.classId.value,
        classroomId: f.classroomId.value,
        dayOfWeek: parseInt(f.dayOfWeek.value),
        startSection: parseInt(f.startSection.value),
        endSection: parseInt(f.endSection.value),
        weeks: f.weeks.value || '1-16',
        courseName: data.courses.find(c => c.id === f.courseId.value)?.name || '',
        teacherName: data.teachers.find(t => t.id === f.teacherId.value)?.name || '',
        classroomName: data.classrooms.find(r => r.id === f.classroomId.value)?.name || '',
        className: data.classes.find(c => c.id === f.classId.value)?.name || ''
    };
    
    if(isOnline){
        await fetch(API+'/schedules', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(item)});
    }
    
    data.schedules.push(item);
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    closeModal();
    loadTeacherSchedule();
}

async function doAutoSchedule(){
    const checkboxes = document.querySelectorAll('input[name="teacher"]:checked');
    const teacherIds = Array.from(checkboxes).map(c => c.value);
    const week = document.getElementById('autoScheduleWeek').value;
    
    closeModal();
    
    if(isOnline){
        try {
            const res = await fetch(API+'/schedules/auto', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({teacherIds: teacherIds.length > 0 ? teacherIds : null, specificWeeks: week !== 'all' ? week : null})
            });
            const result = await res.json();
            alert(`智能排课完成！添加了 ${result.added} 条课表`);
            await loadAllData();
            loadTeacherSchedule();
        } catch(e) {
            alert('排课失败: ' + e.message);
        }
    } else {
        alert('离线模式暂不支持智能排课');
    }
}

async function clearSchedule(){
    if(!confirm('确定清空所有排课?')) return;
    
    if(isOnline){
        await fetch(API+'/schedules', {method: 'DELETE'});
    }
    
    data.schedules = [];
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    loadTeacherSchedule();
}

async function deleteCourse(id){
    if(!confirm('确定删除?')) return;
    if(isOnline) await fetch(API+'/courses/'+id, {method: 'DELETE'});
    data.courses = data.courses.filter(c => c.id !== id);
    localStorage.setItem('finecourse_data', JSON.stringify(data));
    renderCourses();
    loadStats();
}

